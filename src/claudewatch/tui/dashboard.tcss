/* claudewatch dashboard layout - two-column */

#dashboard {
    layout: horizontal;
    height: 1fr;
    padding: 0 1;
}

/* Left column: usage-focused */
#left-col {
    width: 1fr;
    margin: 0 1 0 0;
}

/* Right column: context + events */
#right-col {
    width: 1fr;
}

/* Row 1: matching heights */
#today-usage {
    height: 20;
    border: solid $primary;
    padding: 1;
    margin: 0 0 1 0;
}

#context-health {
    height: 20;
    border: solid $secondary;
    padding: 1;
    margin: 0 0 1 0;
    overflow-y: auto;
}

/* Row 2: matching heights */
#timeline {
    height: 14;
    border: solid $accent;
    padding: 1;
    margin: 0 0 1 0;
}

#context-growth {
    height: 14;
    border: solid $accent;
    padding: 1;
    margin: 0 0 1 0;
}

/* Row 3: fill remaining space */
#session-list {
    height: 1fr;
    min-height: 8;
    border: solid $primary;
    padding: 0;
}

#event-log {
    height: 1fr;
    min-height: 8;
    border: solid $secondary;
    padding: 1;
}

/* Widget title styling */
.widget-title {
    text-style: bold;
    color: $text;
    margin-bottom: 1;
}

.stat-label {
    color: $text-muted;
}

.stat-value {
    text-style: bold;
}

.cost-value {
    color: $warning;
    text-style: bold;
}

.quota-warning {
    color: $error;
    text-style: bold;
}
