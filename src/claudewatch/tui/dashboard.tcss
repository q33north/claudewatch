/* claudewatch dashboard layout - 3-up top, full-width bottom */

#dashboard {
    height: 1fr;
    padding: 0 1;
}

/* Top row: three panels side by side */
#top-row {
    height: 20;
    margin: 0 0 1 0;
}

#today-usage {
    width: 1fr;
    height: 1fr;
    padding: 1 2;
    border-right: solid $primary;
}

#context-growth {
    width: 1fr;
    height: 1fr;
    padding: 1 2;
    border-right: solid $primary;
}

#context-health {
    width: 1fr;
    height: 1fr;
    padding: 1 2;
    overflow: hidden;
}

/* Bottom row: session list spans full width */
#session-list {
    height: 1fr;
    min-height: 8;
    border: solid $primary;
    padding: 0;
}

/* Widget title styling */
.widget-title {
    text-style: bold;
    color: $text;
    margin-bottom: 1;
}

.stat-label {
    color: $text-muted;
}

.stat-value {
    text-style: bold;
}

.cost-value {
    color: $warning;
    text-style: bold;
}

.quota-warning {
    color: $error;
    text-style: bold;
}
