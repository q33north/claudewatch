/* claudewatch dashboard layout - 2x2 grid */

#dashboard {
    height: 1fr;
    padding: 0 1;
}

/* Top row: TodayUsage + Grid 1 */
#top-row {
    height: 1fr;
    margin: 0 0 0 0;
}

/* Bottom row: Grid 2 + Grid 3 */
#bottom-row {
    height: 1fr;
    margin: 0 0 0 0;
}

#today-usage {
    width: 1fr;
    height: 1fr;
    padding: 1 2;
    border: solid $primary;
}

#grid-1 {
    width: 1fr;
    height: 1fr;
    padding: 1 2;
    border: solid $primary;
}

#grid-2 {
    width: 1fr;
    height: 1fr;
    padding: 1 2;
    border: solid $primary;
}

#grid-3 {
    width: 1fr;
    height: 1fr;
    padding: 1 2;
    border: solid $primary;
}

/* Widget title styling */
.widget-title {
    text-style: bold;
    color: $text;
    margin-bottom: 1;
}

.stat-label {
    color: $text-muted;
}

.stat-value {
    text-style: bold;
}

.cost-value {
    color: $warning;
    text-style: bold;
}

.quota-warning {
    color: $error;
    text-style: bold;
}
